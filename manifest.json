// ===================== GERAÇÃO DO PDF =====================
function buildProposalHTML(includeAutoPrint) {
  const planKey     = state.plan;
  const antecipType = state.antecipType;
  const pd          = PLANS[planKey][antecipType];
  const isAut       = antecipType === 'aut';
  const estab       = document.getElementById('estab-name').value.trim() || '—';
  const promoter    = document.getElementById('promoter-name').value.trim();
  const inclComp    = document.getElementById('pdf-incl-comp').checked;
  const today       = new Date().toLocaleDateString('pt-BR', { day:'2-digit', month:'long', year:'numeric' });

  const p   = n => (n * 100).toFixed(2).replace('.', ',') + '%';
  const brl = n => 'R$ ' + n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  // ── Dados da Simulação de Faturamento Mensal (se preenchidos) ──
  const msFatVal  = parseFloat(document.getElementById('ms-fat').value);
  const msPctDeb  = parseFloat(document.getElementById('ms-pct-deb').value)  || 0;
  const msPctCred = parseFloat(document.getElementById('ms-pct-cred').value) || 0;
  const msPctParc = parseFloat(document.getElementById('ms-pct-parc').value) || 0;
  const msAvgInst = parseInt(document.getElementById('ms-avg-inst').value);
  const msSumPct  = msPctDeb + msPctCred + msPctParc;
  const msValid   = msFatVal > 0 && Math.abs(msSumPct - 100) < 0.5;

  let monthlySimData = null;
  if (msValid) {
    const brandMS = state.brand;
    const gDebMS  = calcVero(brandMS, 'debito',  1,         state.inclAdv);
    const gCredMS = calcVero(brandMS, 'credito', 1,         state.inclAdv);
    const gParcMS = calcVero(brandMS, 'parc',    msAvgInst, state.inclAdv);

    const isVeroCompMS  = state.compMode === 'vero';
    const isParcTableMS = state.compMode === 'parc-table';
    const compMS = (!isVeroCompMS && !isParcTableMS) ? getComp() : null;

    const cDebMS  = isVeroCompMS ? calcCompVero(brandMS, 'debito', 1)          : isParcTableMS ? calcCompParcTable('debito', 1)          : calcComp('debito', 1, compMS);
    const cCredMS = isVeroCompMS ? calcCompVero(brandMS, 'credito', 1)         : isParcTableMS ? calcCompParcTable('credito', 1)         : calcComp('credito', 1, compMS);
    const cParcMS = isVeroCompMS ? calcCompVero(brandMS, 'parc', msAvgInst)    : isParcTableMS ? calcCompParcTable('parc', msAvgInst)    : calcComp('parc', msAvgInst, compMS);

    const volDebMS  = msFatVal * (msPctDeb  / 100);
    const volCredMS = msFatVal * (msPctCred / 100);
    const volParcMS = msFatVal * (msPctParc / 100);

    const veroLiqMS =
      (gDebMS  ? volDebMS  * (1 - gDebMS.total)  : volDebMS) +
      (gCredMS ? volCredMS * (1 - gCredMS.total) : volCredMS) +
      (gParcMS ? volParcMS * (1 - gParcMS.total) : volParcMS);

    let compLiqMS = null;
    if (cDebMS || cCredMS || cParcMS) {
      compLiqMS =
        (cDebMS  ? volDebMS  * (1 - cDebMS.total)  : volDebMS) +
        (cCredMS ? volCredMS * (1 - cCredMS.total) : volCredMS) +
        (cParcMS ? volParcMS * (1 - cParcMS.total) : volParcMS);
    }

    monthlySimData = {
      fat: msFatVal, pctDeb: msPctDeb, pctCred: msPctCred, pctParc: msPctParc, avgInst: msAvgInst,
      veroLiq: veroLiqMS, compLiq: compLiqMS,
      gainMonthly: compLiqMS !== null ? veroLiqMS - compLiqMS : null,
      compLabel: isVeroCompMS ? `ZAZ ${state.compPlan}` : 'Concorrente'
    };
  }

  const instRows = [
    { label:'Débito',       mdr: pd.vm?.deb,   inst:0,  isParc:false, isDebito:true },
    { label:'Crédito 1x',   mdr: pd.vm?.cred,  inst:1,  isParc:false },
    { label:'Parcelado 2x', mdr: pd.vm?.p2a6,  inst:2,  isParc:true  },
    { label:'Parcelado 3x', mdr: pd.vm?.p2a6,  inst:3,  isParc:true  },
    { label:'Parcelado 4x', mdr: pd.vm?.p2a6,  inst:4,  isParc:true  },
    { label:'Parcelado 5x', mdr: pd.vm?.p2a6,  inst:5,  isParc:true  },
    { label:'Parcelado 6x', mdr: pd.vm?.p2a6,  inst:6,  isParc:true  },
    { label:'Parcelado 7x', mdr: pd.vm?.p7a12, inst:7,  isParc:true  },
    { label:'Parcelado 8x', mdr: pd.vm?.p7a12, inst:8,  isParc:true  },
    { label:'Parcelado 9x', mdr: pd.vm?.p7a12, inst:9,  isParc:true  },
    { label:'Parcelado 10x',mdr: pd.vm?.p7a12, inst:10, isParc:true  },
    { label:'Parcelado 11x',mdr: pd.vm?.p7a12, inst:11, isParc:true  },
    { label:'Parcelado 12x',mdr: pd.vm?.p7a12, inst:12, isParc:true  },
    { label:'Parcelado 13x',mdr: pd.vm?.p7a12, inst:13, isParc:true  },
    { label:'Parcelado 14x',mdr: pd.vm?.p7a12, inst:14, isParc:true  },
    { label:'Parcelado 15x',mdr: pd.vm?.p7a12, inst:15, isParc:true  },
    { label:'Parcelado 16x',mdr: pd.vm?.p7a12, inst:16, isParc:true  },
    { label:'Parcelado 17x',mdr: pd.vm?.p7a12, inst:17, isParc:true  },
    { label:'Parcelado 18x',mdr: pd.vm?.p7a12, inst:18, isParc:true  },
  ];

  const showLiq  = document.getElementById('pdf-show-liq').checked;

  // ── Usa o valor da venda simulada como base, se preenchido; senão cai no padrão de R$1.000 ──
  const saleValueForPdf = parseFloat(document.getElementById('saleValue').value);
  const hasSaleValuePdf = saleValueForPdf > 0;
  const pdfBasis = hasSaleValuePdf ? saleValueForPdf : 1000;

  // ── Resolve comparison label & data ──────────────────────────
  const mode     = state.compMode;
  let compLabel2 = '';
  let compSubtitle2 = '';
  let getCComp   = null; // fn(r) -> rate | null

  if (inclComp) {
    if (mode === 'vero') {
      const cpd    = PLANS[state.compPlan][state.compAntecipType];
      const cIsAut = state.compAntecipType === 'aut';
      compLabel2   = `ZAZ ${state.compPlan}`;
      compSubtitle2 = `ZAZ ${planKey} vs ZAZ ${state.compPlan} · ${isAut?'Automática':'Opcional'} × ${cIsAut?'Automática':'Opcional'} · Visa/Mastercard`;
      getCComp = r => {
        const cMDR = getMDR(cpd, 'vm', r.isDebito ? 'debito' : r.isParc ? 'parc' : 'credito', r.inst);
        if (cMDR == null) return null;
        const fator = r.isDebito ? 0 : r.isParc ? (r.inst + 1) / 2 : 1;
        const cAdv  = (!r.isDebito && (cIsAut || state.compInclAdv)) ? cpd.antecip * fator : 0;
        return 1 - (1 - cMDR) * (1 - cAdv);
      };
    } else if (mode === 'parc-table') {
      const pt   = getParcTable();
      compLabel2 = 'Concorrente';
      compSubtitle2 = `Vero vs Concorrente (taxa composta informada) · Visa/Mastercard`;
      getCComp = r => r.isDebito ? pt.deb : r.isParc ? pt[r.inst] : pt[1];
    } else {
      const comp = getComp();
      compLabel2 = 'Concorrente';
      compSubtitle2 = `Vero vs Concorrente (MDR + antecip. informados) · Visa/Mastercard`;
      getCComp = r => {
        let cBase = r.isDebito ? comp.debito : r.isParc ? (r.inst <= 6 ? comp.p2a6 : comp.p7a12) : comp.credito;
        if (cBase == null) return null;
        const fator = r.isDebito ? 0 : r.isParc ? (r.inst + 1) / 2 : 1;
        return 1 - (1 - cBase) * (1 - comp.antecip * fator);
      };
    }
  }

  // ── Unified table rows ────────────────────────────────────────
  const instTableRows = instRows.map(r => {
    const fator   = r.isDebito ? 0 : r.isParc ? (r.inst + 1) / 2 : 1;
    const advRate = (!r.isDebito && (isAut || state.inclAdv)) ? pd.antecip * fator : 0;
    const aComp   = r.mdr != null ? 1 - (1 - r.mdr) * (1 - advRate) : null;
    const liqBasis = aComp != null ? brl(pdfBasis * (1 - aComp)) : '—';

    let compCols = '';
    if (inclComp) {
      const cComp = getCComp(r);
      const diff  = (aComp != null && cComp != null) ? (cComp - aComp) * pdfBasis : null;
      const diffTd = diff == null ? `<td class="g-eq">—</td>`
        : Math.abs(diff) < 0.05 ? `<td class="g-eq">≈</td>`
        : diff > 0 ? `<td class="g-pos">▼ ${brl(diff)}</td>`
        : `<td class="g-neg">▲ ${brl(Math.abs(diff))}</td>`;
      compCols = `<td class="muted">${cComp != null ? p(cComp) : '—'}</td>${diffTd}`;
    }

    const liqCol = showLiq ? `<td class="liq">${liqBasis}</td>` : '';
    return `<tr>
      <td>${r.label}</td>
      <td class="comp">${aComp != null ? p(aComp) : '—'}</td>
      ${compCols}${liqCol}
    </tr>`;
  }).join('');

  // Unified table header
  const liqBasisLabel = hasSaleValuePdf ? `Líquido (venda de ${brl(saleValueForPdf)})` : 'Líquido / R$1.000';
  const ganhoLabel     = hasSaleValuePdf ? 'Ganho (R$)' : 'Ganho / R$1k';
  const compHeaders2 = inclComp
    ? `<th class="r">Taxa — ${compLabel2}</th><th class="c">${ganhoLabel}</th>`
    : '';
  const liqHeader = showLiq ? `<th class="r hlg">${liqBasisLabel}</th>` : '';
  const veroColLabel = inclComp ? `Taxa Composta — ZAZ ${planKey}` : 'Taxa Composta';
  const basisNote = hasSaleValuePdf
    ? `Valores calculados sobre a venda simulada de ${brl(saleValueForPdf)}`
    : `Líquido calculado sobre R$1.000 vendidos (referência — preencha "Valor da venda" no simulador para usar o valor real do cliente)`;
  const instTableSub = inclComp ? `${compSubtitle2} · ${basisNote}` : `Taxa composta (MDR + antecipação) · Visa/Mastercard${showLiq ? ' · ' + basisNote : ''}`;

  const instTableHTML = `
    <div style="margin-top:14px">
      <div class="sec-title">📊 ${hasSaleValuePdf ? `Simulação por Parcela — Venda de ${brl(saleValueForPdf)}` : 'Taxa Efetiva por Parcela'} — Visa / Mastercard</div>
      <div class="sec-sub">${instTableSub}</div>
      <table>
        <thead><tr>
          <th>Modalidade</th>
          <th class="r hl">${veroColLabel}</th>
          ${compHeaders2}${liqHeader}
        </tr></thead>
        <tbody>${instTableRows}</tbody>
      </table>
    </div>`;

  // compHTML is now empty — comparison integrated into main table
  let compHTML = '';

  const baseRows = [
    { label:'Débito',           vm: pd.vm?.deb,   elo: pd.elo?.deb,   vc: pd.vc?.deb   },
    { label:'Crédito 1x',       vm: pd.vm?.cred,  elo: pd.elo?.cred,  vc: pd.vc?.cred  },
    { label:'Parcelado 2–6x',   vm: pd.vm?.p2a6,  elo: pd.elo?.p2a6,  vc: pd.vc?.p2a12 },
    { label:'Parcelado 7–18x',  vm: pd.vm?.p7a12, elo: pd.elo?.p7a12, vc: pd.vc?.p2a12 },
    { label:'PIX',              vm: pd.pix,        elo: pd.pix,        vc: null          },
    { label:'Voucher Banricard', vm: pd.ban,       elo: pd.ban,        vc: null          },
  ];

  const baseTableRows = baseRows.map(r => `
    <tr>
      <td>${r.label}</td>
      <td class="rate">${r.vm  != null ? p(r.vm)  : '—'}</td>
      <td class="rate">${r.elo != null ? p(r.elo) : '—'}</td>
      <td class="rate">${r.vc  != null ? p(r.vc)  : '—'}</td>
    </tr>`).join('');

  // ── Seção de Projeção de Faturamento Mensal ────────────────────
  let monthlySectionHTML = '';
  if (monthlySimData) {
    const ms = monthlySimData;
    const brandLabelMS = state.brand === 'vm' ? 'Visa/Mastercard' : state.brand === 'elo' ? 'Elo/Cabal' : state.brand === 'vc' ? 'VerdeCard' : state.brand === 'ban' ? 'Banricard' : 'PIX';
    const gainAnnualMS = ms.gainMonthly !== null ? ms.gainMonthly * 12 : null;

    monthlySectionHTML = `
      <div style="margin-top:16px">
        <div class="sec-title">📈 Projeção de Faturamento Mensal</div>
        <div class="sec-sub">Faturamento estimado: ${brl(ms.fat)}/mês · ${brandLabelMS} · Mix: ${ms.pctDeb}% débito · ${ms.pctCred}% crédito 1x · ${ms.pctParc}% parcelado (${ms.avgInst}x médio)</div>
        <div class="ms-pdf-grid">
          <div class="ms-pdf-box vero">
            <div class="ms-pdf-label">Líquido Mensal — ZAZ ${planKey}</div>
            <div class="ms-pdf-value">${brl(ms.veroLiq)}</div>
          </div>
          ${ms.compLiq !== null ? `
          <div class="ms-pdf-box comp">
            <div class="ms-pdf-label">Líquido Mensal — ${ms.compLabel}</div>
            <div class="ms-pdf-value">${brl(ms.compLiq)}</div>
          </div>` : `
          <div class="ms-pdf-box comp">
            <div class="ms-pdf-label">Comparativo</div>
            <div style="font-size:10px;color:#8A8A9A;padding-top:4px">Sem dados de comparação preenchidos</div>
          </div>`}
        </div>
        ${ms.gainMonthly !== null ? `
        <div class="ms-pdf-gain ${ms.gainMonthly < 0 ? 'negative' : ''}">
          ${ms.gainMonthly >= 0
            ? `✅ ZAZ ${planKey} rende +${brl(ms.gainMonthly)} a mais por mês`
            : `⚠️ ${ms.compLabel} rende +${brl(Math.abs(ms.gainMonthly))} a mais por mês`}
        </div>
        <div class="ms-pdf-annual">Projeção em 12 meses: ${ms.gainMonthly >= 0 ? '+' : '-'}${brl(Math.abs(gainAnnualMS))}</div>` : ''}
      </div>`;
  }

  const LOGO_URL   = 'https://www.sejavero.com.br/bom/multimidia/bomd99im_vero_logo-positivo.svg';

  const html = `<!DOCTYPE html>
<html lang="pt-BR"><head>
<meta charset="UTF-8"/>
<title>Proposta Vero — ${estab}</title>
<style>
@page { size:A4 portrait; margin:0; }
*{ box-sizing:border-box; margin:0; padding:0; }
body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;
  font-size:13px; color:#1C1C1E; background:#fff; line-height:1.5;
  -webkit-print-color-adjust:exact; print-color-adjust:exact;
}

/* ── HEADER ──────────────────────────────────── */
.hd{
  background:#0A1972;
  padding:0 28px;
  display:flex; align-items:stretch; justify-content:space-between;
  min-height:72px;
}
.hd-left{
  display:flex; align-items:center; gap:0;
  border-right:1px solid rgba(255,255,255,0.15);
  padding-right:24px; margin-right:24px;
}
.hd-logo{ height:30px; display:block; }
.hd-sep{ width:1px; background:rgba(255,255,255,0.15); margin:0 20px; align-self:stretch; }
.hd-zaz{
  display:flex; flex-direction:column; justify-content:center;
  color:rgba(255,255,255,0.75); font-size:10px; font-weight:600; letter-spacing:.3px;
}
.hd-zaz strong{ color:#fff; font-size:13px; font-weight:800; letter-spacing:-.2px; }
.hd-right{
  display:flex; flex-direction:column; justify-content:center;
  align-items:flex-end; color:#fff;
}
.hd-doc{ font-size:16px; font-weight:800; letter-spacing:-.3px; }
.hd-date{ font-size:10px; color:rgba(255,255,255,.65); margin-top:3px; }
.hd-badge{
  margin-top:7px; display:inline-flex; align-items:center; gap:5px;
  background:#00C2DC; color:#0A1972;
  padding:3px 11px; border-radius:20px; font-size:9.5px; font-weight:800; letter-spacing:.3px;
}

/* ── CYAN STRIPE ──────────────────────────────── */
.stripe{ height:4px; background:linear-gradient(90deg,#00C2DC,#0A1972); }

/* ── ESTAB BAR ─────────────────────────────────── */
.estab-bar{
  background:#F4F6FB; border-bottom:1px solid #DDE2EF;
  padding:12px 28px; display:flex; align-items:center; gap:32px; flex-wrap:wrap;
}
.eb-main{ flex:1; min-width:200px; }
.eb-label{ font-size:8.5px; font-weight:800; text-transform:uppercase; letter-spacing:.7px; color:#8A8A9A; }
.eb-name{ font-size:18px; font-weight:800; color:#0A1972; margin-top:1px; letter-spacing:-.3px; }
.eb-promoter{ font-size:10.5px; color:#6C6C70; margin-top:4px; }
.eb-promoter strong{ color:#1C1C1E; }
.eb-meta{ display:flex; gap:20px; flex-wrap:wrap; }
.em-item{ display:flex; flex-direction:column; gap:1px; }
.em-label{ font-size:8px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:#8A8A9A; }
.em-val{ font-size:12px; font-weight:700; color:#1C1C1E; }

/* ── PLAN BANNER ───────────────────────────────── */
.plan-banner{
  margin:16px 28px 0;
  background:linear-gradient(135deg,#0A1972 0%,#1535A8 60%,#1a45c8 100%);
  border-radius:10px; padding:14px 20px;
  display:flex; align-items:center; justify-content:space-between; gap:12px; color:#fff;
}
.pb-left{ display:flex; align-items:center; gap:14px; }
.pb-dot{
  width:40px; height:40px; border-radius:10px;
  background:rgba(255,255,255,0.13); border:1.5px solid rgba(255,255,255,0.25);
  display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;
}
.pb-plan{ font-size:17px; font-weight:800; letter-spacing:-.3px; }
.pb-sub{ font-size:9.5px; color:rgba(255,255,255,.72); margin-top:2px; }
.pb-right{ display:flex; gap:7px; flex-wrap:wrap; align-items:center; }
.pb-chip{ padding:4px 11px; border-radius:20px; font-size:9px; font-weight:800; letter-spacing:.3px; }
.ch-aut{ background:#00C2DC; color:#0A1972; }
.ch-opc{ background:rgba(255,255,255,.15); color:#fff; border:1px solid rgba(255,255,255,.3); }
.ch-fat{ background:rgba(255,255,255,.1); color:rgba(255,255,255,.85); }

/* ── BRANDS ────────────────────────────────────── */
.brands{ margin:10px 28px 0; display:flex; gap:6px; flex-wrap:wrap; }
.br-pill{ padding:4px 11px; border-radius:20px; font-size:9.5px; font-weight:800; border:1.5px solid; }
.br-vm { background:#EEF2FF; color:#0A1972;  border-color:#0A1972; }
.br-elo{ background:#FFF8E1; color:#7A5C00; border-color:#D4A800; }
.br-vc { background:#E8F5E9; color:#1a6b30; border-color:#4CAF50; }
.br-ban{ background:#FDE8E8; color:#8B1A1A; border-color:#D44; }
.br-pix{ background:#E0F7FA; color:#005F6B; border-color:#00BCD4; }

/* ── CONTENT WRAPPER ───────────────────────────── */
.content{ padding:0 28px; }

/* ── TWO COLS (base taxa + antecip) ─────────────── */
.two-cols{ display:grid; grid-template-columns:1fr 220px; gap:14px; margin-top:14px; }

/* ── SECTION ───────────────────────────────────── */
.sec-title{
  font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:.8px;
  color:#0A1972; border-bottom:2px solid #0A1972; padding-bottom:5px; margin-bottom:3px;
}
.sec-sub{ font-size:8.5px; color:#8A8A9A; margin-bottom:8px; }

/* ── ANTECIP CARD ──────────────────────────────── */
.antecip-card{
  background:linear-gradient(160deg,rgba(0,194,220,.08),rgba(10,25,114,.04));
  border:1.5px solid #00C2DC; border-radius:9px; padding:14px 16px;
  display:flex; flex-direction:column; justify-content:center; gap:4px;
}
.ac-label{ font-size:8px; font-weight:800; text-transform:uppercase; letter-spacing:.6px; color:#009DB3; }
.ac-rate{ font-size:26px; font-weight:800; color:#0A1972; letter-spacing:-1px; line-height:1.1; }
.ac-unit{ font-size:10px; font-weight:600; color:#0A1972; }
.ac-type{ font-size:9px; font-weight:700; color:#009DB3; margin-top:4px; }
.ac-sub{ font-size:8.5px; color:#8A8A9A; line-height:1.5; margin-top:3px; }

/* ── PROJEÇÃO MENSAL ──────────────────────────── */
.ms-pdf-grid{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:8px; }
.ms-pdf-box{
  border-radius:10px; padding:14px 16px;
}
.ms-pdf-box.vero{ background:linear-gradient(160deg,rgba(0,194,220,.1),rgba(10,25,114,.05)); border:1.5px solid #00C2DC; }
.ms-pdf-box.comp{ background:#F4F6FB; border:1.5px solid #DDE2EF; }
.ms-pdf-label{ font-size:8.5px; font-weight:800; text-transform:uppercase; letter-spacing:.6px; color:#8A8A9A; margin-bottom:4px; }
.ms-pdf-value{ font-size:22px; font-weight:800; color:#0A1972; letter-spacing:-.5px; }
.ms-pdf-box.comp .ms-pdf-value{ color:#6C6C70; }
.ms-pdf-mix{ font-size:9px; color:#8A8A9A; margin-top:10px; line-height:1.6; }
.ms-pdf-gain{
  margin-top:10px; padding:11px 16px; border-radius:9px;
  background:#F0FFF4; border:1px solid #28A745; color:#1a7a3a;
  font-size:12px; font-weight:800; text-align:center;
}
.ms-pdf-gain.negative{ background:#FFF2F2; border-color:#FF3B30; color:#c0392b; }
.ms-pdf-annual{ font-size:9px; color:#8A8A9A; text-align:center; margin-top:6px; }

/* ── TABLES ─────────────────────────────────────── */
table{ width:100%; border-collapse:collapse; }
thead th{
  background:#0A1972; color:#fff; padding:6px 10px;
  text-align:left; font-size:9px; font-weight:800;
  text-transform:uppercase; letter-spacing:.4px; white-space:nowrap;
}
thead th.r{ text-align:right; }
thead th.c{ text-align:center; }
thead th.hl{ background:#00C2DC; color:#0A1972; }
thead th.hlg{ background:#1a6b30; color:#fff; }
tbody tr{ border-bottom:1px solid #ECEEF4; }
tbody tr:nth-child(even){ background:#F7F8FC; }
tbody tr:last-child{ border-bottom:none; }
tbody td{ padding:5.5px 10px; vertical-align:middle; font-size:12px; }
td.r{ text-align:right; }
td.c{ text-align:center; }
td.rate{ font-weight:700; color:#0A1972; text-align:right; }
td.comp{ font-weight:800; color:#0A1972; background:rgba(10,25,114,.04); text-align:right; }
td.liq{ font-weight:700; color:#1a6b30; text-align:right; }
td.muted{ color:#8A8A9A; text-align:right; }
td.antecip{ color:#009DB3; text-align:right; }

/* ── DIVIDER ─────────────────────────────────────── */
.divider{ height:1px; background:#DDE2EF; margin:14px 28px; }
.page-break{ page-break-before:always; }

/* ── COMP HEADER ─────────────────────────────────── */
.comp-banner{
  background:#F4F6FB; border:1px solid #DDE2EF; border-radius:8px;
  padding:10px 14px; display:flex; align-items:center; gap:10px; margin-bottom:8px;
}
.comp-banner .cb-icon{ font-size:18px; }
.comp-banner .cb-title{ font-size:11px; font-weight:800; color:#0A1972; }
.comp-banner .cb-sub{ font-size:8.5px; color:#8A8A9A; margin-top:1px; }
td.g-pos{ color:#1a6b30; font-weight:700; text-align:center; }
td.g-neg{ color:#B91C1C; font-weight:700; text-align:center; }
td.g-eq { color:#8A8A9A; text-align:center; }

/* ── FOOTER ──────────────────────────────────────── */
.pdf-footer{
  margin-top:18px; padding:12px 28px 20px;
  border-top:1px solid #DDE2EF;
  display:flex; justify-content:space-between; align-items:flex-end; gap:16px;
}
.ft-notes{ font-size:7.5px; color:#AAAAB8; line-height:1.8; max-width:420px; }
.ft-brand{ text-align:right; }
.ft-logo{ height:18px; opacity:.7; }
