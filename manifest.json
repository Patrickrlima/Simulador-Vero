  document.getElementById(groupId).querySelectorAll('.tgl').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById(groupId).querySelectorAll('.tgl').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      state[stateKey] = btn.dataset.val;
      if (cb) cb();
      render();
