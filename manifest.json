${includeAutoPrint ? `
<script>
  window.onload = () => {
    const imgs = document.querySelectorAll('img');
    let done = 0, total = imgs.length;
    const tryPrint = () => { done++; if(done >= total) setTimeout(window.print, 250); };
    if(total === 0){ setTimeout(window.print, 250); return; }
    imgs.forEach(img => { if(img.complete) tryPrint(); else { img.onload = tryPrint; img.onerror = tryPrint; } });
  };
<\/script>` : ''}
</body></html>`;

  return html;
}

function generatePDF() {
  const html = buildProposalHTML(true);
  const win = window.open('', '_blank');
  win.document.write(html);
  win.document.close();
}

function openWhatsAppWithAttachReminder(estab, filename) {
  const promoter = document.getElementById('promoter-name').value.trim();
  let msg = `Olá! Segue a proposta de taxas *Vero* para *${estab}*. 📄\n\n`;
  msg += `📎 Anexe aqui o arquivo *${filename}* que acabou de ser baixado no seu computador.`;
  if (promoter) msg += `\n\n_Atendimento: ${promoter}_`;
  window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
}

// ===================== COMPARTILHAR PDF DA PROPOSTA (arquivo real) =====================
function slugify(text) {
  return (text || 'proposta')
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-zA-Z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .toLowerCase() || 'proposta';
}

function setWhatsAppBtnState(loading) {
  const btn = document.getElementById('whatsapp-pdf-btn');
  if (!btn) return;
  if (loading) {
    btn.dataset.originalHtml = btn.innerHTML;
    btn.innerHTML = '<span>⏳</span> Gerando PDF...';
    btn.disabled = true;
  } else {
    if (btn.dataset.originalHtml) btn.innerHTML = btn.dataset.originalHtml;
    btn.disabled = false;
  }
}

async function shareProposalPDF() {
  if (typeof window.jspdf === 'undefined' || typeof html2canvas === 'undefined') {
    alert('Não foi possível carregar os componentes necessários para gerar o PDF (verifique sua conexão com a internet). Você ainda pode usar o botão "Exportar Proposta PDF" tradicional.');
    return;
  }

  setWhatsAppBtnState(true);

  // Renderiza a proposta num iframe escondido pra tirar um "print" fiel dela
  const html = buildProposalHTML(false);
  const iframe = document.createElement('iframe');
  iframe.style.position = 'fixed';
  iframe.style.top = '-10000px';
  iframe.style.left = '-10000px';
  iframe.style.width = '794px';   // ~ largura de A4 a 96dpi
  iframe.style.height = '1123px'; // ~ altura de A4 a 96dpi (ajustado depois pelo conteúdo real)
  iframe.style.border = 'none';
  document.body.appendChild(iframe);

  try {
    await new Promise((resolve, reject) => {
      iframe.onload = resolve;
      iframe.onerror = reject;
      iframe.srcdoc = html;
      setTimeout(resolve, 4000); // trava de segurança caso onload não dispare
    });

    const doc = iframe.contentDocument;
    // Ajusta a altura do iframe para o conteúdo real, senão a captura fica cortada
    const fullHeight = Math.max(doc.body.scrollHeight, doc.documentElement.scrollHeight);
    iframe.style.height = fullHeight + 'px';
    await new Promise(r => setTimeout(r, 200)); // dá um tempo pro reflow

    const canvas = await html2canvas(doc.body, {
      scale: 2,
      useCORS: true,
      backgroundColor: '#ffffff',
      width: 794,
      windowWidth: 794
    });

    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF('p', 'mm', 'a4');
    const pageWidthMM  = 210;
    const pageHeightMM = 297;
    const imgHeightMM  = (canvas.height * pageWidthMM) / canvas.width;
    const imgData = canvas.toDataURL('image/jpeg', 0.92);

    let heightLeft = imgHeightMM;
    let position = 0;
    pdf.addImage(imgData, 'JPEG', 0, position, pageWidthMM, imgHeightMM);
    heightLeft -= pageHeightMM;
    while (heightLeft > 0) {
      position = heightLeft - imgHeightMM;
      pdf.addPage();
      pdf.addImage(imgData, 'JPEG', 0, position, pageWidthMM, imgHeightMM);
      heightLeft -= pageHeightMM;
    }

    const estab    = document.getElementById('estab-name').value.trim() || 'Cliente';
    const filename = `Proposta-Vero-${slugify(estab)}.pdf`;
    const blob     = pdf.output('blob');
    const file     = new File([blob], filename, { type: 'application/pdf' });

    if (navigator.canShare && navigator.canShare({ files: [file] })) {
      await navigator.share({
        files: [file],
        title: 'Proposta Vero × ZAZ Vendas',
        text: `Segue a proposta de taxas Vero para ${estab}.`
      });
    } else {
      // Desktop / navegador sem suporte: baixa o PDF e abre o WhatsApp Web com aviso
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      alert(`O PDF "${filename}" foi baixado. O WhatsApp vai abrir com uma mensagem pronta — é só anexar esse arquivo na conversa (o navegador não permite anexar automaticamente por segurança).`);
      openWhatsAppWithAttachReminder(estab, filename);
    }
  } catch (err) {
    if (err && err.name === 'AbortError') {
      // Usuário cancelou o compartilhamento — não é erro
    } else {
      console.error(err);
      alert('Não foi possível gerar o PDF para compartilhamento. Tente novamente ou use o botão "Exportar Proposta PDF".');
    }
  } finally {
    iframe.remove();
    setWhatsAppBtnState(false);
  }
}

// ===================== ENVIAR POR WHATSAPP =====================
function sendWhatsApp() {
  const saleValue = parseFloat(document.getElementById('saleValue').value);
  if (isNaN(saleValue) || saleValue <= 0) {
    alert('Preencha o valor da venda antes de enviar a simulação.');
    return;
  }

  const { brand, method, inst, inclAdv } = state;
  const g = calcVero(brand, method, inst, inclAdv);
  if (!g) {
    alert('Essa modalidade não está disponível para a bandeira selecionada.');
    return;
  }

  const estab = document.getElementById('estab-name').value.trim() || 'Cliente';
  const gL = saleValue * (1 - g.total);

  const methodLabel =
    method === 'debito'  ? 'Débito' :
    method === 'credito' ? 'Crédito à Vista' :
    `Crédito ${inst}x`;

  const brandLabel =
    brand === 'vm'  ? 'Visa/Mastercard' :
    brand === 'elo' ? 'Elo/Cabal'       :
    brand === 'vc'  ? 'VerdeCard'       :
    brand === 'ban' ? 'Banricard'       : 'PIX';

  let msg = `*Simulação de Taxas — Vero × ZAZ Vendas*\n\n`;
  msg += `🏪 Estabelecimento: ${estab}\n`;
  msg += `📋 Plano: ZAZ ${state.plan} (${state.antecipType === 'aut' ? 'Antecipação Automática' : 'Antecipação Opcional'})\n`;
  msg += `💳 Venda: ${fmtBRL(saleValue)} — ${methodLabel} — ${brandLabel}\n\n`;
  msg += `📊 Taxa total: ${fmtPct(g.total)}\n`;
  msg += `✅ Você recebe: *${fmtBRL(gL)}*\n`;

  // Comparação, se houver dados preenchidos
  const isVeroComp  = state.compMode === 'vero';
  const isParcTable = state.compMode === 'parc-table';
  const comp = (!isVeroComp && !isParcTable) ? getComp() : null;
  const c = isVeroComp   ? calcCompVero(brand, method, inst)
          : isParcTable  ? calcCompParcTable(method, inst)
          : (brand === 'vm' || brand === 'elo') ? calcComp(method, inst, comp) : null;

  if (c) {
    const cL   = saleValue * (1 - c.total);
    const gain = gL - cL;
    const compLabel = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente atual';
    msg += `\n⚫ ${compLabel}: ${fmtPct(c.total)} → ${fmtBRL(cL)}\n`;
    if (gain > 0.5) {
      msg += `\n🎉 A Vero rende *+${fmtBRL(gain)}* a mais nesta venda!`;
    } else if (gain < -0.5) {
      msg += `\n⚠️ O concorrente rende +${fmtBRL(Math.abs(gain))} a mais nesta venda.`;
    } else {
      msg += `\nTaxas praticamente equivalentes.`;
    }
  }

  msg += `\n\n_Simulação gerada em ${new Date().toLocaleDateString('pt-BR')}_`;

  const url = `https://wa.me/?text=${encodeURIComponent(msg)}`;
  window.open(url, '_blank');
}

// ===================== SIMULAÇÃO DE FATURAMENTO MENSAL =====================
function renderMonthlySim() {
  const resultEl = document.getElementById('ms-result');
  const sumEl    = document.getElementById('ms-pct-sum');

  const fat     = parseFloat(document.getElementById('ms-fat').value);
  const pctDeb  = parseFloat(document.getElementById('ms-pct-deb').value)  || 0;
  const pctCred = parseFloat(document.getElementById('ms-pct-cred').value) || 0;
  const pctParc = parseFloat(document.getElementById('ms-pct-parc').value) || 0;
  const avgInst = parseInt(document.getElementById('ms-avg-inst').value);

  const sumPct = pctDeb + pctCred + pctParc;
  const isOk   = Math.abs(sumPct - 100) < 0.5;

  sumEl.className = 'ms-sum-indicator ' + (isOk ? 'ok' : 'warn');
  sumEl.innerHTML = isOk
    ? `<span>✅ Soma: ${sumPct.toFixed(0)}%</span><span>Mix completo</span>`
    : `<span>⚠️ Soma: ${sumPct.toFixed(0)}%</span><span>Faltam ${(100 - sumPct).toFixed(0)}% para 100%</span>`;

  if (!fat || fat <= 0 || sumPct === 0) {
    resultEl.innerHTML = '<div class="empty-state" style="padding:16px 0"><div class="empty-icon">📈</div>Preencha o faturamento e o mix de vendas para projetar.</div>';
    return;
  }

  const brand = state.brand;
  const gDeb  = calcVero(brand, 'debito',  1,       state.inclAdv);
  const gCred = calcVero(brand, 'credito', 1,       state.inclAdv);
  const gParc = calcVero(brand, 'parc',    avgInst, state.inclAdv);

  const isVeroComp  = state.compMode === 'vero';
  const isParcTable = state.compMode === 'parc-table';
  const comp = (!isVeroComp && !isParcTable) ? getComp() : null;

  const cDeb  = isVeroComp ? calcCompVero(brand, 'debito', 1)         : isParcTable ? calcCompParcTable('debito', 1)         : calcComp('debito', 1, comp);
  const cCred = isVeroComp ? calcCompVero(brand, 'credito', 1)        : isParcTable ? calcCompParcTable('credito', 1)        : calcComp('credito', 1, comp);
  const cParc = isVeroComp ? calcCompVero(brand, 'parc', avgInst)     : isParcTable ? calcCompParcTable('parc', avgInst)     : calcComp('parc', avgInst, comp);

  const volDeb  = fat * (pctDeb  / 100);
  const volCred = fat * (pctCred / 100);
  const volParc = fat * (pctParc / 100);

  const veroLiq =
    (gDeb  ? volDeb  * (1 - gDeb.total)  : volDeb) +
    (gCred ? volCred * (1 - gCred.total) : volCred) +
    (gParc ? volParc * (1 - gParc.total) : volParc);

  let compLiq = null;
  if (cDeb || cCred || cParc) {
    compLiq =
      (cDeb  ? volDeb  * (1 - cDeb.total)  : volDeb) +
      (cCred ? volCred * (1 - cCred.total) : volCred) +
      (cParc ? volParc * (1 - cParc.total) : volParc);
  }

  const gainMonthly = compLiq !== null ? veroLiq - compLiq : null;
  const gainAnnual  = gainMonthly !== null ? gainMonthly * 12 : null;

  const compLabel = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente';
  const winnerName = isVeroComp ? `ZAZ ${state.plan}` : 'Vero';
  const loserName  = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente';

  resultEl.innerHTML = `
    <div class="two-col" style="margin-bottom:0">
      <div class="liquido-box vero-box">
        <div class="lb-label">Líquido mensal (Vero)</div>
        <div class="lb-value">${fmtBRL(veroLiq)}</div>
      </div>
      ${compLiq !== null ? `
      <div class="liquido-box comp-box">
        <div class="lb-label">Líquido mensal (${compLabel})</div>
        <div class="lb-value" style="color:var(--subtext)">${fmtBRL(compLiq)}</div>
      </div>` : ''}
    </div>
    ${gainMonthly !== null ? `
      <div class="gain-banner ${gainMonthly > 0.5 ? 'positive' : gainMonthly < -0.5 ? 'negative' : 'neutral'}" style="margin-top:12px">
        <span class="gb-icon">${gainMonthly > 0.5 ? '✅' : gainMonthly < -0.5 ? '❌' : '➖'}</span>
        <span>
          ${gainMonthly > 0.5
            ? `${winnerName} rende <strong>+${fmtBRL(gainMonthly)}/mês</strong> a mais`
            : gainMonthly < -0.5
            ? `${loserName} rende <strong>+${fmtBRL(Math.abs(gainMonthly))}/mês</strong> a mais`
            : 'Resultado mensal praticamente equivalente'}
        </span>
      </div>
      ${Math.abs(gainAnnual) > 1 ? `
      <div style="margin-top:10px;text-align:center;font-size:12px;color:var(--subtext)">
        Projeção em 12 meses: <strong style="color:var(--text)">${gainMonthly > 0 ? '+' : ''}${fmtBRL(gainAnnual)}</strong>
      </div>` : ''}
    ` : `<p style="font-size:12px;color:var(--subtext);margin-top:10px">Preencha as taxas do concorrente (ou selecione outro plano Vero) para comparar.</p>`}
  `;
}

// Auto-ajuste: ao editar Débito ou Crédito 1x, o Parcelado completa até 100% sozinho
function autoBalanceParc() {
  const deb  = parseFloat(document.getElementById('ms-pct-deb').value)  || 0;
  const cred = parseFloat(document.getElementById('ms-pct-cred').value) || 0;
  const resto = Math.max(0, Math.min(100, 100 - deb - cred));
  document.getElementById('ms-pct-parc').value = resto;
}

['ms-pct-deb', 'ms-pct-cred'].forEach(id => {
  document.getElementById(id).addEventListener('input', () => {
    autoBalanceParc();
    renderMonthlySim();
  });
});

['ms-fat','ms-pct-parc','ms-avg-inst'].forEach(id => {
  document.getElementById(id).addEventListener('input', renderMonthlySim);
});

// ===================== CONSULTA DE CNPJ (BrasilAPI) =====================
function maskCNPJInput(value) {
  const d = value.replace(/\D/g, '').slice(0, 14);
  let out = d;
  if (d.length > 2)  out = d.slice(0,2) + '.' + d.slice(2);
  if (d.length > 5)  out = out.slice(0,6) + '.' + out.slice(6);
  if (d.length > 8)  out = out.slice(0,10) + '/' + out.slice(10);
  if (d.length > 12) out = out.slice(0,15) + '-' + out.slice(15);
  return out;
}

document.getElementById('cnpj-input').addEventListener('input', e => {
  e.target.value = maskCNPJInput(e.target.value);
});

document.getElementById('cnpj-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') buscarCNPJ();
});

function isValidCNPJ(cnpjDigits) {
  if (cnpjDigits.length !== 14 || /^(\d)\1{13}$/.test(cnpjDigits)) return false;
  const calcDV = (base) => {
    const weights = base.length === 12
      ? [5,4,3,2,9,8,7,6,5,4,3,2]
      : [6,5,4,3,2,9,8,7,6,5,4,3,2];
    let sum = 0;
    for (let i = 0; i < base.length; i++) sum += parseInt(base[i]) * weights[i];
    const rest = sum % 11;
    return rest < 2 ? 0 : 11 - rest;
  };
  const base12 = cnpjDigits.slice(0, 12);
  const dv1 = calcDV(base12);
  const dv2 = calcDV(base12 + dv1);
  return cnpjDigits === base12 + String(dv1) + String(dv2);
}

function toggleCollapse(cardId) {
  document.getElementById(cardId).classList.toggle('collapsed');
}

function openCnpjModal() {
  document.getElementById('cnpj-modal-overlay').classList.add('open');
  document.getElementById('cnpj-input').focus();
}

function closeCnpjModal() {
  document.getElementById('cnpj-modal-overlay').classList.remove('open');
}

function openIntroModal() {
  document.getElementById('intro-modal-overlay').classList.add('open');
}

function closeIntroModal() {
  document.getElementById('intro-modal-overlay').classList.remove('open');
  try { localStorage.setItem('vero_sim_intro_seen', '1'); } catch (e) { /* localStorage indisponível, sem problema */ }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeCnpjModal(); closeIntroModal(); }
});

// Mostra o guia de boas-vindas automaticamente na primeira visita
(function autoShowIntro() {
  try {
    if (!localStorage.getItem('vero_sim_intro_seen')) {
      // Pequeno atraso: dá tempo do navegador mobile estabilizar a barra de endereço
      // antes de abrir o modal em tela cheia, evitando corte visual.
      setTimeout(openIntroModal, 300);
    }
  } catch (e) {
    // localStorage bloqueado (ex: aba anônima restrita) — não mostra automaticamente, mas o botão "Como Usar" continua disponível
  }
})();

function fmtCEP(cep) {
  if (!cep) return null;
  const d = cep.replace(/\D/g, '');
  return d.length === 8 ? `${d.slice(0,5)}-${d.slice(5)}` : cep;
}

function fmtDataBR(iso) {
  if (!iso) return null;
  const m = iso.match(/^(\d{4})-(\d{2})-(\d{2})/);
  return m ? `${m[3]}/${m[2]}/${m[1]}` : iso;
}

function fmtCapitalSocial(v) {
  if (v === null || v === undefined) return null;
  const n = Number(v);
  if (isNaN(n)) return null;
  return 'R$ ' + n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

async function buscarCNPJ() {
  const input = document.getElementById('cnpj-input');
  const btn   = document.getElementById('cnpj-search-btn');
  const area  = document.getElementById('cnpj-result-area');
  const digits = input.value.replace(/\D/g, '');

  if (digits.length !== 14) {
    area.innerHTML = `<div class="cnpj-error"><span>⚠️</span><span>Digite um CNPJ completo (14 dígitos).</span></div>`;
    return;
  }
  if (!isValidCNPJ(digits)) {
    area.innerHTML = `<div class="cnpj-error"><span>⚠️</span><span>Esse CNPJ não parece válido — confira os números digitados.</span></div>`;
    return;
  }

  btn.disabled = true;
  area.innerHTML = `
    <div class="cnpj-loading">
      <div class="cnpj-spinner"></div>
      <div>Consultando dados públicos...</div>
    </div>`;

  try {
    const resp = await fetch(`https://brasilapi.com.br/api/cnpj/v1/${digits}`);
    if (resp.status === 404) {
      area.innerHTML = `<div class="cnpj-error"><span>🔍</span><span>CNPJ não encontrado na base da Receita Federal.</span></div>`;
      return;
    }
    if (!resp.ok) {
      area.innerHTML = `<div class="cnpj-error"><span>⚠️</span><span>Não foi possível consultar agora (erro ${resp.status}). Tente novamente em instantes.</span></div>`;
      return;
    }
    const data = await resp.json();
    renderCnpjData(data);
  } catch (err) {
    area.innerHTML = `<div class="cnpj-error"><span>⚠️</span><span>Falha de conexão ao consultar o CNPJ. Verifique sua internet e tente novamente.</span></div>`;
  } finally {
    btn.disabled = false;
  }
}

function renderCnpjData(data) {
  const area = document.getElementById('cnpj-result-area');

  const situacao = (data.descricao_situacao_cadastral || '').toUpperCase();
  const badgeClass =
    situacao.includes('ATIVA')    ? 'ativa'    :
    situacao.includes('BAIXADA')  ? 'baixada'  :
    situacao.includes('SUSPENSA') ? 'suspensa' :
    situacao.includes('INAPTA')   ? 'inapta'   : 'outro';

  const enderecoParts = [
    data.logradouro,
    data.numero,
    data.complemento
  ].filter(Boolean).join(', ');
  const bairroMuniUf = [data.bairro, data.municipio && data.uf ? `${data.municipio}/${data.uf}` : data.municipio].filter(Boolean).join(' — ');
  const cepFmt = fmtCEP(data.cep);

  const porteTxt = typeof data.porte === 'object' && data.porte ? (data.porte.descricao || data.porte.text || '') : (data.porte || null);

  const socios = Array.isArray(data.qsa) ? data.qsa : [];
  const sociosHtml = socios.length
    ? `<div class="cnpj-socios-wrap">
         <div class="cnpj-socios-title">Quadro de Sócios (${socios.length})</div>
         ${socios.map(s => `<span class="cnpj-socio-chip">${s.nome_socio || s.nome || '—'} <small>· ${s.qualificacao_socio || s.qual || ''}</small></span>`).join('')}
       </div>`
    : '';

  const cnaesSecArr = Array.isArray(data.cnaes_secundarios) ? data.cnaes_secundarios : [];
  const cnaeSecTxt = cnaesSecArr.length
    ? cnaesSecArr.slice(0, 3).map(c => c.descricao || c.text).filter(Boolean).join(' · ') + (cnaesSecArr.length > 3 ? ` (+${cnaesSecArr.length - 3})` : '')
    : null;

  const infoItem = (label, value, full) => value
    ? `<div class="cnpj-info-item${full ? ' full' : ''}">
         <div class="cnpj-info-label">${label}</div>
         <div class="cnpj-info-value">${value}</div>
       </div>` : '';

  area.innerHTML = `
    <div class="cnpj-card">
      <div class="cnpj-card-head">
        <div>
          <div class="cnpj-razao">${data.razao_social || '—'}</div>
          ${data.nome_fantasia ? `<div class="cnpj-fantasia">${data.nome_fantasia}</div>` : ''}
          <div class="cnpj-cnpj-num">${maskCNPJInput(data.cnpj || '')}</div>
        </div>
        <span class="cnpj-badge ${badgeClass}">${data.descricao_situacao_cadastral || 'N/D'}</span>
      </div>

      <div class="cnpj-info-grid">
        ${infoItem('CNAE Principal', data.cnae_fiscal_descricao, true)}
        ${infoItem('CNAEs Secundários', cnaeSecTxt, true)}
        ${infoItem('Endereço', enderecoParts, true)}
        ${infoItem('Bairro / Cidade', bairroMuniUf)}
        ${infoItem('CEP', cepFmt)}
        ${infoItem('Natureza Jurídica', data.natureza_juridica)}
        ${infoItem('Porte', porteTxt)}
        ${infoItem('Data de Abertura', fmtDataBR(data.data_inicio_atividade))}
        ${infoItem('Capital Social', fmtCapitalSocial(data.capital_social))}
        ${infoItem('Telefone', data.ddd_telefone_1)}
        ${infoItem('E-mail', data.email)}
      </div>

      ${sociosHtml}

      <div class="cnpj-actions">
        <button class="cnpj-btn-use" onclick="useCnpjData(${JSON.stringify(data.razao_social || '').replace(/"/g,'&quot;')}, ${JSON.stringify(data.nome_fantasia || '').replace(/"/g,'&quot;')})">
          ✅ Usar no formulário
        </button>
        <button class="cnpj-btn-source" onclick="window.open('https://solucoes.receita.fazenda.gov.br/Servicos/cnpjreva/cnpjreva_solicitacao.asp','_blank')">
          📄 Ver na Receita
        </button>
        <button class="cnpj-btn-ccmei" onclick="window.open('https://www.gov.br/empresas-e-negocios/pt-br/empreendedor/servicos-para-mei/emissao-de-comprovante-ccmei','_blank')">
          🧾 Emitir CCMEI
        </button>
      </div>
      <div class="cnpj-ccmei-note">
        O CCMEI é específico para clientes <strong>MEI</strong>. O botão abre a página oficial da Receita — lá será
        necessário informar CPF e data de nascimento do titular, além de confirmar a verificação "não sou um robô".
      </div>
    </div>
    <div class="cnpj-source-note">
      Dados via BrasilAPI (fonte pública, atualizados periodicamente pela Receita Federal).
      Para fins legais/contratuais, confirme sempre no site oficial da Receita.
    </div>
  `;
}

function useCnpjData(razaoSocial, nomeFantasia) {
  const nome = nomeFantasia && nomeFantasia.trim() ? nomeFantasia : razaoSocial;
  const estabInput = document.getElementById('estab-name');
  estabInput.value = nome || '';
  closeCnpjModal();
  estabInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
  estabInput.focus();
}

// Init
render();

// Registra o service worker (permite instalar como app e funcionar offline).
// Só funciona quando hospedado via https:// (não funciona abrindo o arquivo direto do disco).
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js').catch(() => {
      // Falha silenciosa: se não conseguir registrar (ex: aberto via file://), o site
      // continua funcionando normalmente, só sem o modo instalável/offline.
    });
  });
}
</script>
</body>
</html>
