// ===================== UTILITÁRIOS =====================
function fmtPct(n)  { return (n * 100).toFixed(2).replace('.', ',') + '%'; }
function fmtBRL(n)  {
  return 'R$ ' + n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function getPlanData() {
  return PLANS[state.plan][state.antecipType];
}

function getAdvFactor(method, inst) {
  if (method === 'debito' || method === 'ban' || method === 'pix') return 0;
  if (method === 'credito') return 1;
  return (inst + 1) / 2;
}

function getMDR(pd, brand, method, inst) {
  if (brand === 'ban') return pd.ban;
  if (brand === 'pix') return pd.pix;
  const b = pd[brand];
  if (!b) return null;
  if (method === 'debito')  return b.deb  !== undefined ? b.deb  : null;
  if (method === 'credito') return b.cred !== undefined ? b.cred : null;
  if (method === 'parc') {
    if (brand === 'vc') return b.p2a12; // VerdeCard tem taxa única para parcelado (2x a 18x)
    return inst <= 6 ? b.p2a6 : b.p7a12; // 7x a 18x usam a mesma taxa p7a12
  }
  return null;
}

function calcVero(brand, method, inst, inclAdv) {
  const pd  = getPlanData();
  const mdr = getMDR(pd, brand, method, inst);
  if (mdr === null) return null;

  const isAut = state.antecipType === 'aut';
  const fator = getAdvFactor(method, inst);

  let advRate = 0;
  if (fator > 0) {
    if (isAut || inclAdv) {
      advRate = pd.antecip * fator;
    }
  }

  const total = 1 - (1 - mdr) * (1 - advRate);
  return { mdr, fator, advRate, total };
}

function getComp() {
  const p = id => {
    const v = parseFloat(document.getElementById(id).value);
    return isNaN(v) || v === 0 ? null : v / 100;
  };
  return {
    debito:  p('c-debito'),
    credito: p('c-credito'),
    p2a6:    p('c-p2a6'),
    p7a12:   p('c-p7a12'),
    antecip: p('c-antecip') ?? 0
  };
}

function calcComp(method, inst, comp) {
  let base;
  if (method === 'debito')  base = comp.debito;
  else if (method === 'credito') base = comp.credito;
  else if (method === 'parc') base = inst <= 6 ? comp.p2a6 : comp.p7a12;
  else return null;
  if (base === null) return null;

  const fator   = getAdvFactor(method, inst);
  const advRate = comp.antecip * fator;
  const total   = 1 - (1 - base) * (1 - advRate);
  return { base, advRate, total };
}

function getParcTable() {
  const p = id => {
    const v = parseFloat(document.getElementById(id).value);
    return isNaN(v) || v === 0 ? null : v / 100;
  };
  return {
    deb: p('pt-deb'),
    1:  p('pt-1x'),
    2:  p('pt-2x'),  3:  p('pt-3x'),  4:  p('pt-4x'),
    5:  p('pt-5x'),  6:  p('pt-6x'),  7:  p('pt-7x'),
    8:  p('pt-8x'),  9:  p('pt-9x'),  10: p('pt-10x'),
    11: p('pt-11x'), 12: p('pt-12x'),
    13: p('pt-13x'), 14: p('pt-14x'), 15: p('pt-15x'),
    16: p('pt-16x'), 17: p('pt-17x'), 18: p('pt-18x')
  };
}

function calcCompParcTable(method, inst) {
  const pt = getParcTable();
  let rate;
  if (method === 'debito')  rate = pt.deb;
  else if (method === 'credito') rate = pt[1];
  else if (method === 'parc')    rate = pt[inst];
  else return null;
  if (rate === null || rate === undefined) return null;
  // Taxa já composta — sem nenhum cálculo adicional
  return { total: rate, mdr: rate, advRate: 0, fator: 0, isComposite: true };
}

function calcCompVero(brand, method, inst) {
  const pd    = PLANS[state.compPlan][state.compAntecipType];
  const mdr   = getMDR(pd, brand, method, inst);
  if (mdr === null) return null;

  const isAut = state.compAntecipType === 'aut';
  const fator = getAdvFactor(method, inst);
  let advRate = 0;
  if (fator > 0 && (isAut || state.compInclAdv)) {
    advRate = pd.antecip * fator;
  }
  const total = 1 - (1 - mdr) * (1 - advRate);
  return { mdr, fator, advRate, total };
}

function updateCompVeroChip() {
  const pd   = PLANS[state.compPlan][state.compAntecipType];
  const isAut = state.compAntecipType === 'aut';
  document.getElementById('comp-vero-antecip-rate').textContent = fmtPct(pd.antecip) + ' a.m.';
  document.getElementById('comp-vero-antecip-desc').textContent = isAut
    ? 'Antecipação automática embutida'
    : 'Antecipação opcional — incluída no cálculo se marcado acima';
  document.getElementById('comp-incl-adv-wrap').classList.toggle('hidden', isAut);
}

// ===================== RENDER TABELA DO PLANO =====================
function renderPlanTable() {
  const pd  = getPlanData();
  const plan = state.plan;
  const type = state.antecipType;

  document.getElementById('plan-title').textContent   = `ZAZ ${plan}`;
  document.getElementById('plan-fat-sub').textContent = `Faturamento mínimo: ${PLANS[plan].fat}`;

  const badge = document.getElementById('plan-type-badge');
  badge.textContent = type === 'aut' ? 'AUTOMÁTICA' : 'OPCIONAL';
  badge.className   = `plan-type-badge ${type}`;

  document.getElementById('antecip-rate-display').textContent = fmtPct(pd.antecip) + ' a.m.';
  document.getElementById('antecip-type-desc').textContent =
    type === 'aut'
      ? 'Antecipação automática embutida nas taxas de crédito/parcelado'
      : 'Cliente escolhe se quer antecipar; taxa aplicada somente se solicitado';

  const rows = [
    { label: 'Débito',           vm: pd.vm?.deb,    elo: pd.elo?.deb,    vc: pd.vc?.deb,   ban: pd.ban, pix: pd.pix, isDebito: true },
    { label: 'Crédito 1x',       vm: pd.vm?.cred,   elo: pd.elo?.cred,   vc: pd.vc?.cred,  ban: null,   pix: null    },
    { label: 'Parcelado 2–6x',   vm: pd.vm?.p2a6,   elo: pd.elo?.p2a6,   vc: pd.vc?.p2a12, ban: null,   pix: null    },
    { label: 'Parcelado 7–18x',  vm: pd.vm?.p7a12,  elo: pd.elo?.p7a12,  vc: pd.vc?.p2a12, ban: null,   pix: null    },
  ];

  const cell = (val, highlight) => {
    if (val === null || val === undefined) return '<td class="dash">—</td>';
    return `<td class="${highlight ? 'hl' : ''}">${fmtPct(val)}</td>`;
  };

  let html = '';
  for (const r of rows) {
    html += `<tr>
      <td>${r.label}</td>
      ${cell(r.vm,  true)}
      ${cell(r.elo, false)}
      ${cell(r.vc,  false)}
      ${cell(r.ban, false)}
      ${cell(r.pix, false)}
    </tr>`;
  }

  // Antecipação row
  const antecipLabel = type === 'aut' ? 'Antecipação Auto (a.m.)' : 'Antecipação Opcional (a.m.)';
  html += `<tr style="background:rgba(0,194,220,0.05)">
    <td style="color:var(--accent-dark);font-weight:800">${antecipLabel}</td>
    <td class="hl-accent" colspan="2">${fmtPct(pd.antecip)}</td>
    <td class="dash" colspan="3">—</td>
  </tr>`;

  document.getElementById('plan-tbody').innerHTML = html;

  document.getElementById('plan-antecip-foot').innerHTML =
    type === 'aut'
      ? `<strong>Antecipação automática:</strong> ${fmtPct(pd.antecip)} a.m. — já refletida nas taxas de crédito e parcelado`
      : `<strong>Antecipação opcional:</strong> ${fmtPct(pd.antecip)} a.m. — cobrada somente quando o cliente solicita a antecipação`;
}

// ===================== RENDER RESULTADO PRINCIPAL =====================
function render() {
  renderPlanTable();

  const saleValue = parseFloat(document.getElementById('saleValue').value);
  const { brand, method, inst, inclAdv } = state;

  if (isNaN(saleValue) || saleValue <= 0) {
    document.getElementById('result-title').textContent = 'Resultado da Simulação';
    document.getElementById('result-sub').textContent   = 'Preencha o valor da venda para calcular';
    document.getElementById('result-body').innerHTML    =
      '<div class="empty-state"><div class="empty-icon">🧮</div>Informe o valor da venda para ver o resultado.</div>';
    renderComparison(null);
    renderInstallmentList(null);
    renderMonthlySim();
    return;
  }

  const g = calcVero(brand, method, inst, inclAdv);
  if (!g) {
    document.getElementById('result-body').innerHTML =
      '<div class="empty-state"><div class="empty-icon">⚠️</div>Modalidade não disponível para esta bandeira.</div>';
    renderComparison(null);
    renderInstallmentList(saleValue);
    renderMonthlySim();
    return;
  }

  const gL = saleValue * (1 - g.total);
  const gC = saleValue * g.total;

  const isVeroComp  = state.compMode === 'vero';
  const isParcTable = state.compMode === 'parc-table';

  let c, cL, cC, gain;
  if (isVeroComp) {
    c = calcCompVero(brand, method, inst);
  } else if (isParcTable) {
    c = calcCompParcTable(method, inst);
  } else {
    const comp = getComp();
    c = (brand === 'vm' || brand === 'elo') ? calcComp(method, inst, comp) : null;
  }
  cL   = c ? saleValue * (1 - c.total) : null;
  cC   = c ? saleValue * c.total       : null;
  gain = cL !== null ? gL - cL : null;

  const methodLabel =
    method === 'debito'  ? 'Débito' :
    method === 'credito' ? 'Crédito à Vista' :
    method === 'pix'     ? 'PIX' :
    method === 'ban'     ? 'Voucher Banricard' :
    `Crédito ${inst}x`;

  const brandLabel =
    brand === 'vm'  ? 'Visa / Mastercard' :
    brand === 'elo' ? 'Elo / Cabal'       :
    brand === 'vc'  ? 'VerdeCard'         :
    brand === 'ban' ? 'Banricard'         : 'PIX';

  const compLabel = isVeroComp
    ? `ZAZ ${state.compPlan} · ${state.compAntecipType === 'aut' ? 'Automática' : 'Opcional'}`
    : isParcTable ? 'Concorrente (taxa composta)' : 'Concorrente';

  document.getElementById('result-title').textContent = `${methodLabel} — ${brandLabel}`;
  document.getElementById('result-sub').textContent   = `Plano ZAZ ${state.plan} · ${state.antecipType === 'aut' ? 'Antecipação Automática' : 'Antecipação Opcional'}`;

  const advRow = g.advRate > 0
    ? `<div class="detail-row">
         <span class="dk">Antecipação (fator ${g.fator.toFixed(1)}×)</span>
         <span class="dv">${fmtPct(g.advRate)}</span>
       </div>` : '';

  const compAdvRow = (c && c.advRate > 0)
    ? `<div class="detail-row">
         <span class="dk">Antecipação (fator ${c.fator ? c.fator.toFixed(1) : ''}×)</span>
         <span class="dv">${fmtPct(c.advRate)}</span>
       </div>` : '';

  const compSideEmpty = isVeroComp
    ? `<p style="font-size:12px;color:var(--subtext);padding-top:8px;line-height:1.5">Bandeira não disponível neste plano.</p>`
    : isParcTable
    ? `<p style="font-size:12px;color:var(--subtext);padding-top:8px;line-height:1.5">Preencha a taxa composta para esta modalidade.</p>`
    : `<p style="font-size:12px;color:var(--subtext);padding-top:8px;line-height:1.5">Preencha as taxas do concorrente para comparar.</p>`;

  const compSide = c
    ? `<div>
         <div class="side-label comp">⚫ ${compLabel}</div>
         ${isParcTable
           ? `<div class="detail-row">
                <span class="dk">Taxa composta (já com antecip.)</span>
                <span class="dv" style="color:var(--subtext)">${fmtPct(c.total)}</span>
              </div>`
           : `<div class="detail-row">
                <span class="dk">${isVeroComp ? 'Taxa MDR' : 'Taxa base'}</span>
                <span class="dv">${fmtPct(isVeroComp ? c.mdr : c.base)}</span>
              </div>
              ${compAdvRow}`
         }
         <div class="detail-row total-row comp-total">
           <span class="dk"><strong>Taxa total</strong></span>
           <span class="dv">${fmtPct(c.total)}</span>
         </div>
       </div>`
    : `<div>
         <div class="side-label comp">⚫ ${compLabel}</div>
         ${compSideEmpty}
       </div>`;

  const liqCompLabel = isVeroComp ? `Você recebe (${compLabel})` : 'Você recebe (Concorrente)';
  const liqComp = cL !== null
    ? `<div class="liquido-box comp-box">
         <div class="lb-label">${liqCompLabel}</div>
         <div class="lb-value" style="color:var(--subtext)">${fmtBRL(cL)}</div>
         <div class="lb-cost">Custo: ${fmtBRL(cC)}</div>
       </div>` : '';

  const parcelaInfo = method === 'parc'
    ? `<div class="lb-parcela">Por parcela: <strong>${fmtBRL(gL / inst)}</strong></div>` : '';

  const winnerName  = isVeroComp ? `ZAZ ${state.plan}` : 'Vero';
  const loserName   = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente';

  const gainHtml = gain !== null
    ? `<div class="gain-banner ${gain > 0.005 ? 'positive' : gain < -0.005 ? 'negative' : 'neutral'}">
         <span class="gb-icon">${gain > 0.005 ? '✅' : gain < -0.005 ? '❌' : '➖'}</span>
         <span>
           ${gain > 0.005
             ? `${winnerName} rende <strong>+${fmtBRL(gain)}</strong> a mais nesta venda`
             : gain < -0.005
             ? `${loserName} rende <strong>+${fmtBRL(Math.abs(gain))}</strong> a mais nesta venda`
             : 'Taxas praticamente equivalentes'}
         </span>
       </div>` : '';

  const breakevenHtml = buildBreakevenHtml(saleValue);

  document.getElementById('result-body').innerHTML = `
    <div class="two-col">
      <div>
        <div class="side-label">🔵 Vero</div>
        <div class="detail-row">
          <span class="dk">Taxa MDR</span>
          <span class="dv">${fmtPct(g.mdr)}</span>
        </div>
        ${advRow}
        <div class="detail-row total-row">
          <span class="dk"><strong>Taxa total</strong></span>
          <span class="dv">${fmtPct(g.total)}</span>
        </div>
      </div>
      ${compSide}
    </div>
    <div class="two-col" style="margin-bottom:0">
      <div class="liquido-box vero-box">
        <div class="lb-label">Você recebe (Vero)</div>
        <div class="lb-value">${fmtBRL(gL)}</div>
        <div class="lb-cost">Custo: ${fmtBRL(gC)}</div>
        ${parcelaInfo}
      </div>
      ${liqComp}
    </div>
    ${gainHtml}
    ${breakevenHtml}
  `;

  renderComparison(saleValue);
  renderInstallmentList(saleValue);
  renderMonthlySim();
}

// ===================== RENDER COMPARATIVO =====================
function renderComparison(saleValue) {
  const tbody    = document.getElementById('comp-tbody');
  const mobCards = document.getElementById('mob-cards');

  if (!saleValue) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--subtext);font-size:13px">Preencha o valor da venda para ver o comparativo.</td></tr>`;
    mobCards.innerHTML = '';
    return;
  }

  const brand      = state.brand;
  const inclAdv    = state.inclAdv;
  const isVeroComp  = state.compMode === 'vero';
  const isParcTable = state.compMode === 'parc-table';
  const comp        = (!isVeroComp && !isParcTable) ? getComp() : null;

  const colLabel2 = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente';

  // Atualiza cabeçalho da tabela
  const ths = document.querySelectorAll('#comp-section thead th');
  if (ths.length >= 6) {
    ths[4].textContent = `Taxa ${colLabel2}`;
    ths[5].textContent = `Líq. ${colLabel2}`;
  }

  // PIX / Banricard — linha única
  if (brand === 'pix' || brand === 'ban') {
    const pd  = getPlanData();
    const mdr = brand === 'pix' ? pd.pix : pd.ban;
    const liq = saleValue * (1 - mdr);
    const tag = brand === 'pix'
      ? '<span class="tag tag-pix">PIX</span>'
      : '<span class="tag tag-debit">Voucher</span>';
    tbody.innerHTML = `
      <tr>
        <td>1x</td><td>${tag}</td>
        <td>${fmtPct(mdr)}</td><td>${fmtBRL(liq)}</td>
        <td><span class="dash">—</span></td>
        <td><span class="dash">—</span></td>
        <td><span class="dash">—</span></td>
      </tr>`;
    mobCards.innerHTML = '';
    return;
  }

  let tableHTML = '';
  let cardsHTML = '';

  for (const row of COMP_ROWS) {
    const g  = calcVero(brand, row.type, row.inst, inclAdv);
    if (!g) continue;
    const gL = saleValue * (1 - g.total);

    const c  = isVeroComp   ? calcCompVero(brand, row.type, row.inst)
             : isParcTable  ? calcCompParcTable(row.type, row.inst)
             :                calcComp(row.type, row.inst, comp);
    const cL   = c ? saleValue * (1 - c.total) : null;
    const gain = cL !== null ? gL - cL : null;

    const gainTd =
      gain === null ? '<span class="dash">—</span>' :
      gain >  0.005 ? `<span class="g-pos">+${fmtBRL(gain)}</span>` :
      gain < -0.005 ? `<span class="g-neg">${fmtBRL(gain)}</span>` :
      `<span class="g-zero">—</span>`;

    const payTag = row.type === 'debito'
      ? `<span class="tag tag-debit">Débito</span>`
      : `<span class="tag tag-credit">Crédito</span>`;

    tableHTML += `
      <tr>
        <td>${row.label}</td>
        <td>${payTag}</td>
        <td>${fmtPct(g.total)}</td>
        <td>${fmtBRL(gL)}</td>
        <td>${c ? fmtPct(c.total) : '<span class="dash">—</span>'}</td>
        <td>${cL !== null ? fmtBRL(cL) : '<span class="dash">—</span>'}</td>
        <td>${gainTd}</td>
      </tr>`;

    const gainStyle =
      gain === null ? `background:var(--bg);color:var(--subtext)` :
      gain >  0.005 ? `background:var(--success-bg);color:#1a7a3a` :
      gain < -0.005 ? `background:var(--danger-bg);color:#c0392b` :
      `background:var(--bg);color:var(--subtext)`;

    const winnerName = isVeroComp ? `ZAZ ${state.plan}` : 'Vero';
    const loserName  = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente';
    const gainText =
      gain === null ? '—' :
      gain >  0.005 ? `✅ ${winnerName} rende +${fmtBRL(gain)} a mais` :
      gain < -0.005 ? `❌ ${loserName} rende +${fmtBRL(Math.abs(gain))} a mais` :
      '➖ Equivalente';

    cardsHTML += `
      <div class="mob-card">
        <div class="mob-card-head"><div class="mob-parcela">${row.label} ${payTag}</div></div>
        <div class="mob-grid">
          <div class="mob-metric"><div class="mm-label">Taxa ZAZ ${state.plan}</div><div class="mm-val primary">${fmtPct(g.total)}</div></div>
          <div class="mob-metric"><div class="mm-label">Líq. ZAZ ${state.plan}</div><div class="mm-val">${fmtBRL(gL)}</div></div>
          <div class="mob-metric"><div class="mm-label">Taxa ${colLabel2}</div><div class="mm-val muted">${c ? fmtPct(c.total) : '—'}</div></div>
          <div class="mob-metric"><div class="mm-label">Líq. ${colLabel2}</div><div class="mm-val muted">${cL !== null ? fmtBRL(cL) : '—'}</div></div>
        </div>
        ${gain !== null ? `<div class="mob-gain" style="${gainStyle}">${gainText}</div>` : ''}
      </div>`;
  }

  tbody.innerHTML    = tableHTML;
  mobCards.innerHTML = cardsHTML;
}

// ===================== PONTO DE EQUILÍBRIO (BREAKEVEN) =====================
function calcBreakeven(saleValue) {
  const brand = state.brand;
  if (!saleValue || brand === 'pix' || brand === 'ban') return null;

  const isVeroComp  = state.compMode === 'vero';
  const isParcTable = state.compMode === 'parc-table';
  const comp = (!isVeroComp && !isParcTable) ? getComp() : null;

  const points = [];
  for (let n = 1; n <= 18; n++) {
    const method = n === 1 ? 'credito' : 'parc';
    const g = calcVero(brand, method, n, state.inclAdv);
    if (!g) continue;
    const c = isVeroComp   ? calcCompVero(brand, method, n)
            : isParcTable  ? calcCompParcTable(method, n)
            : (brand === 'vm' || brand === 'elo') ? calcComp(method, n, comp) : null;
    if (!c) continue;

    const gL = saleValue * (1 - g.total);
    const cL = saleValue * (1 - c.total);
    points.push({ n, diff: gL - cL });
  }

  if (points.length === 0) return null;

  const THRESHOLD = 0.01; // R$ — abaixo disso, considera empate
  const sign = d => (d > THRESHOLD ? 1 : d < -THRESHOLD ? -1 : 0);

  const segments = [];
  let cur = null;
  for (const pt of points) {
    const s = sign(pt.diff);
    if (!cur || cur.sign !== s) {
      cur = { sign: s, from: pt.n, to: pt.n };
      segments.push(cur);
    } else {
      cur.to = pt.n;
    }
  }
  return segments;
}

function buildBreakevenHtml(saleValue) {
  const segments = calcBreakeven(saleValue);
  if (!segments) return '';

  const isVeroComp = state.compMode === 'vero';
  const winnerName = isVeroComp ? `ZAZ ${state.plan}` : 'Vero';
  const loserName  = isVeroComp ? `ZAZ ${state.compPlan}` : 'Concorrente';
  const label = seg => (seg.from === seg.to ? `${seg.from}x` : `${seg.from}x–${seg.to}x`);

  const allSame = segments.every(s => s.sign === segments[0].sign);
  let text;

  if (allSame) {
    if (segments[0].sign === 1)      text = `<strong>${winnerName}</strong> é mais vantajosa em todas as parcelas simuladas (1x a 18x)`;
    else if (segments[0].sign === -1) text = `<strong>${loserName}</strong> é mais vantajoso em todas as parcelas simuladas (1x a 18x)`;
    else                               text = `Taxas praticamente equivalentes em todas as parcelas (1x a 18x)`;
  } else if (segments.length <= 3) {
    text = segments.map(s => {
      const who = s.sign === 1 ? winnerName : s.sign === -1 ? loserName : 'Empate técnico';
      return `<strong>${label(s)}</strong>: ${who} vence`;
    }).join(' &nbsp;→&nbsp; ');
  } else {
    text = `O resultado varia bastante por parcela — veja a lista completa abaixo para o detalhe`;
  }

  return `
    <div class="breakeven-banner">
      <span class="bb-icon">📈</span>
      <div>
        <div class="bb-label">Ponto de Equilíbrio</div>
        <div class="bb-text">${text}</div>
      </div>
    </div>`;
}

// ===================== RENDER LISTA PARCELA A PARCELA (1x-18x) =====================
function renderInstallmentList(saleValue) {
  const listBody = document.getElementById('installment-list-body');
  const subEl    = document.getElementById('il-sub');
  const brand    = state.brand;

  if (!saleValue || isNaN(saleValue) || saleValue <= 0) {
    subEl.textContent = '1x a 18x · Preencha o valor da venda';
    listBody.innerHTML = '<div class="empty-state"><div class="empty-icon">📋</div>Informe o valor da venda para ver a lista completa.</div>';
    return;
  }

  // PIX / Banricard não parcelam — mostra só a linha à vista
  if (brand === 'pix' || brand === 'ban') {
    const pd  = getPlanData();
    const mdr = brand === 'pix' ? pd.pix : pd.ban;
    const liq = saleValue * (1 - mdr);
    subEl.textContent = brand === 'pix' ? 'PIX · pagamento à vista' : 'Voucher Banricard · pagamento à vista';
    listBody.innerHTML = `
      <div class="il-row il-highlight">
        <span class="il-n">1x</span>
        <span class="il-liq">${fmtBRL(liq)}</span>
        <span class="il-taxa">${fmtPct(mdr)}</span>
      </div>`;
    return;
  }

  const brandLabel =
    brand === 'vm'  ? 'Visa/Mastercard' :
    brand === 'elo' ? 'Elo/Cabal'       : 'VerdeCard';
  subEl.textContent = `${brandLabel} · Plano ZAZ ${state.plan} · ${state.antecipType === 'aut' ? 'Antecip. Automática' : 'Antecip. Opcional'}`;

  let rowsHtml = '';

  // 1x — crédito à vista
  const g1 = calcVero(brand, 'credito', 1, state.inclAdv);
  if (g1) {
    const liq = saleValue * (1 - g1.total);
    const highlight = state.method === 'credito';
    rowsHtml += `
      <div class="il-row ${highlight ? 'il-highlight' : ''}">
        <span class="il-n">1x</span>
        <span class="il-liq">${fmtBRL(liq)}</span>
        <span class="il-taxa">${fmtPct(g1.total)}</span>
      </div>`;
  }

  // 2x a 18x — parcelado
  for (let n = 2; n <= 18; n++) {
    const g = calcVero(brand, 'parc', n, state.inclAdv);
    if (!g) continue;
    const liq = saleValue * (1 - g.total);
    const highlight = state.method === 'parc' && state.inst === n;
    rowsHtml += `
      <div class="il-row ${highlight ? 'il-highlight' : ''}">
        <span class="il-n">${n}x</span>
        <span class="il-liq">${fmtBRL(liq)}</span>
        <span class="il-taxa">${fmtPct(g.total)}</span>
      </div>`;
  }

  listBody.innerHTML = rowsHtml || '<div class="empty-state"><div class="empty-icon">⚠️</div>Parcelamento não disponível para esta bandeira.</div>';
}

// ===================== FILTRO POR FATURAMENTO =====================
function filterPlansByFat() {
  const fat = parseFloat(document.getElementById('faturamento').value);
  const sel = document.getElementById('plan-select');
  const chip = document.getElementById('fat-chip');
  const chipText = document.getElementById('fat-chip-text');
  const chipPlans = document.getElementById('fat-chip-plans');

  if (isNaN(fat) || fat <= 0) {
    // Sem faturamento: habilita todos
    Array.from(sel.options).forEach(o => { o.disabled = false; o.style.color = ''; });
    chip.classList.add('hidden');
    return;
  }

  let available = [];
  let blocked = [];

  Array.from(sel.options).forEach(o => {
    const minFat = PLAN_MIN_FAT[o.value];
    if (minFat <= fat) {
      o.disabled = false;
      o.style.color = '';
      available.push(o.value);
    } else {
      o.disabled = true;
      o.style.color = '#C7C7CC';
      blocked.push(o.value);
    }
  });

  // Se o plano selecionado ficou bloqueado, vai para o melhor disponível
  if (PLAN_MIN_FAT[state.plan] > fat && available.length > 0) {
    const best = available[available.length - 1];
    state.plan = best;
    sel.value = best;
  }

  chip.classList.remove('hidden', 'ok', 'low', 'info');

  if (available.length === 0) {
    chip.classList.add('low');
    chipText.textContent = '⚠️ Faturamento abaixo do mínimo (R$ 3.000)';
    chipPlans.textContent = '';
  } else {
    const fatFmt = fat.toLocaleString('pt-BR', { minimumFractionDigits: 0 });
    chip.classList.add('ok');
    chipText.textContent = `✅ ${available.length} plano${available.length > 1 ? 's' : ''} disponível${available.length > 1 ? 'is' : ''}`;
    chipPlans.textContent = `ZAZ ${available.join(', ')}`;
  }
}

